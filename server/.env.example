# General Config
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database (MongoDB)
MONGODB_URI=mongodb://root:password123@localhost:27017/bharatconnect?authSource=admin

# Cache & Message Queue (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword123

# Security (JWT)
JWT_ACCESS_SECRET=your_jwt_access_secret_key_must_be_long_and_secure
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_must_be_long_and_secure
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary Config
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Config (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=no-reply@bharatconnect.gov.in
